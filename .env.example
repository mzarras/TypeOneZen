DEXCOM_USERNAME=your_dexcom_share_username
DEXCOM_PASSWORD=your_dexcom_share_password
DEXCOM_OUTSIDE_US=false
ALERT_PHONE=+1XXXXXXXXXX
COROS_EMAIL=your_coros_email@example.com
COROS_PASSWORD=your_coros_password
USER_NAME=YourFirstName
# Nightscout (used by ns_sync.py, monitor.py, and the skill's tz_query.py)
NIGHTSCOUT_URL=https://your-nightscout-site.example.com
# Use a READ-ONLY access token — create a dedicated subject (e.g. "zenbot-read")
# with the readable role under Nightscout Admin Tools, never your API_SECRET.
NIGHTSCOUT_TOKEN=your_readonly_access_token
